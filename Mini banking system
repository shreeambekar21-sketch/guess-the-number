
class Account:
    def __init__(self, bal, acc):
        self.balance = bal
        self.account_no = acc

        
#Debit Method
    def debit(self, amount):
        self.balance -= amount
        print( "Rs" , amount , "was debited from your account")
        print("total balance=", self.get_balance())


#Credit Method
    def credit(self, amount):
        self.balance += amount
        print("Rs" , amount , "was credit from your account")
        print("total balance=", self.get_balance())

        

    def get_balance(self):
        return self.balance

        


acc1 = Account(100000, 1234560)
acc1.debit(10000)
acc1.credit(200)
acc1.credit(13000)
